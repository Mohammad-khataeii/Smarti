{
  "name": "smarti-electron",
  "version": "1.0.0",
  "type": "module",
  "author": "Seyedmohammad Khataeipour",
  "description": "Smarti Electron desktop wrapper for React + Node",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_START_URL=http://localhost:3001 electron .",
    "build-client": "cd client && npm run build",
    "package": "npm run build-client && electron-builder",
    "publish": "npm run build-client && electron-builder --publish always"
  },
  "build": {
    "appId": "com.brakelysts.smarti",
    "productName": "Smarti",
    "copyright": "© 2025 Seyedmohammad Khataeipour",
    "icon": "icon.png",
    "files": [
      "main.js",
      "client/build/**/*",
      "server/**/*",
      "python-scripts/**/*",
      "icon.png",
      "LICENSE.txt"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "Smarti-${version}-mac.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Smarti-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE.txt"
    },
    "extraResources": [
      {
        "from": "LICENSE.txt",
        "to": "LICENSE.txt"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Mohammad-khataeii",
        "repo": "Smarti",
        "private": true
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "node-fetch": "^3.3.2"
  },
  "license": "Proprietary"
}
