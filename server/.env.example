# Auth
SECRET_KEY=change_this_to_a_long_random_value

# Optional ML runner settings (defaults exist in code)
PREDICTIONS_ROOT=./predictions
PYTHON_BIN=python
TRAIN_SCRIPT=train_random_forest.py
PREDICT_SCRIPT=predict_random_forest.py

# Database (default in code goes to %USERPROFILE%\.smarti_data\test_results.db)
DB_PATH=

# Artifacts & schema (optional)
ARTIFACTS_DIR=./ml_artifacts
FEATURES_SCHEMA=

# Model settings (optional)
MODEL_TARGET=pass_binary
BIGRAM_TOP_K=50
COOC_TOP_K=50
BIGRAM_TOP_K_PRED=100